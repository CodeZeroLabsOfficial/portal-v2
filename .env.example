# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase (client) — same project as your iOS app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server) — paste JSON from a service account with Firestore access
# Use double quotes and escape inner quotes, or load via GOOGLE_APPLICATION_CREDENTIALS locally
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional local path alternative to FIREBASE_SERVICE_ACCOUNT_JSON
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Explicit project id for Firebase Admin in local/serverless runtimes
FIREBASE_PROJECT_ID=

# Firebase Storage default bucket (server) — required for signed-agreement PNG uploads via Admin SDK.
# Copy exact value from Firebase Console → Project settings → Your apps → storageBucket
# (e.g. your-project.firebasestorage.app). Set the same variable in Vercel → Settings → Environment Variables (Production + Preview as needed).
FIREBASE_STORAGE_BUCKET=

# Vercel Blob (proposal media library — list + staff uploads)
BLOB_READ_WRITE_TOKEN=
# Optional override (default proposal-media-library/)
# PROPOSAL_MEDIA_LIBRARY_PREFIX=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
